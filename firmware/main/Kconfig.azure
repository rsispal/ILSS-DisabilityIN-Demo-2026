menu "Azure IoT Hub Configuration"

    config ILSS_AZURE_IOT_ENABLED
        bool "Enable Azure IoT Hub Support"
        default y
        help
            Enable or disable the Azure IoT Hub integration.
            This requires MQTT with TLS to be enabled.
    
    if ILSS_AZURE_IOT_ENABLED
    
    config ILSS_AZURE_IOT_HUB_HOSTNAME
        string "Azure IoT Hub Hostname"
        default "ILSS-TEST-IOT-HUB.azure-devices.net"
        help
            The hostname of your Azure IoT Hub (e.g., "myiothub.azure-devices.net").
            You can find this in the Azure Portal under your IoT Hub's Overview page.
    
    config ILSS_AZURE_IOT_DEVICE_ID
        string "Azure IoT Device ID"
        default "device01"
        help
            The device ID registered in your Azure IoT Hub.
            For X.509 authentication, this must match the Common Name (CN) 
            in your device certificate.
    
    config ILSS_AZURE_IOT_SERVER_PORT
        int "Azure IoT Hub MQTT Port"
        default 8883
        help
            The MQTT port for Azure IoT Hub. 
            Typically 8883 for TLS connections.
    
    config ILSS_AZURE_IOT_USE_X509
        bool "Use X.509 Certificate Authentication"
        default y
        help
            Enable X.509 certificate-based authentication for Azure IoT Hub.
            When enabled, the device will use client certificates for authentication.
            When disabled, SAS token authentication will be used.
    
    config ILSS_AZURE_IOT_SAS_TOKEN
        string "Azure IoT Hub SAS Token"
        depends on !ILSS_AZURE_IOT_USE_X509
        default ""
        help
            The Shared Access Signature (SAS) token for authenticating with Azure IoT Hub.
            You can generate this using Azure CLI or the Azure Portal.
            Format: SharedAccessSignature sr=...&sig=...&se=...
    
    config ILSS_AZURE_IOT_KEEPALIVE
        int "MQTT Keepalive Interval (seconds)"
        default 60
        range 30 1200
        help
            MQTT Keepalive interval in seconds. The client will send a PINGREQ
            if no other messages have been sent within this period.
            Azure IoT Hub requires keepalive between 30-1200 seconds.
    
    config ILSS_AZURE_IOT_LOG_LEVEL
        int "Azure IoT Hub log level"
        default 3
        range 0 4
        help
            Log level for Azure IoT Hub feature.
            0 = OFF, 1 = ERROR, 2 = WARNING, 3 = INFO, 4 = DEBUG
    
    endif # ILSS_AZURE_IOT_ENABLED
    
endmenu
