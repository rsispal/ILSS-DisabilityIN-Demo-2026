menu "ILSS Digital Twin"

config ILSS_TWIN_ADV_NAME_PREFIX
	string "BLE advertising name prefix"
	default "ILSS-LY"
	help
	  Prefix for the BLE GAP device name. Serial suffix is appended from ble_prov.

config ILSS_TWIN_ENCRYPT_ENABLE
	bool "Enable encrypted twin Data payloads after pairing"
	default y
	help
	  When paired with a factory secret, encrypt packed-protocol Data with AES-256-GCM.

config ILSS_TWIN_HEARTBEAT_LOG_MS
	int "Application heartbeat log interval (ms)"
	default 30000
	range 5000 300000

endmenu
