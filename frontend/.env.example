# PostHog (production only — preview/localhost never initialise)
# From PostHog → Project settings. Both are required by the SDK.
# https://posthog.com/docs/libraries/react
VITE_POSTHOG_PROJECT_TOKEN=phc_xxxxxxxx
# Must match your project region (US or EU):
#   https://us.i.posthog.com
#   https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com
